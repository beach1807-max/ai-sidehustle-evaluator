AI_PROVIDER=mock

# Gemini PoC
# 先留空，之後由我自行申請 Gemini API Key 後填入 .env
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# 是否顯示開發者工具
VITE_SHOW_DEV_TOOLS=false
VITE_ENABLE_DEEP_REPORT=false

# 公開測試每日一般報告免費產出次數
VITE_FREE_EVALUATION_DAILY_LIMIT=2

# 公開測試每日深度報告產出次數
VITE_DEEP_REPORT_DAILY_LIMIT=1

# Google Sheet 回饋收集 webhook，由 Cloudflare Pages Function 使用
GOOGLE_SHEET_WEBHOOK_URL=

# Google Sheet 回饋收集 secret，需與 Google Apps Script 裡的 SECRET 相同
FEEDBACK_SECRET=

# 未來要串 OpenAI 時使用
OPENAI_API_KEY=
OPENAI_MODEL=

# 未來要串 Anthropic 時使用
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
